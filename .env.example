# Copy this file to .env and fill in values before running docker-compose
# NEVER commit the actual .env file — it contains secrets.

# PostgreSQL — use a strong, unique password
POSTGRES_PASSWORD=changeme

# JWT signing key — MUST be at least 32 random characters
# Generate one with: openssl rand -base64 32
JWT_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_32CHARS

# Resend email
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=LeadSense <noreply@yourdomain.com>

# Frontend public URL (used in invitation emails)
FRONTEND_URL=https://yourdomain.com
